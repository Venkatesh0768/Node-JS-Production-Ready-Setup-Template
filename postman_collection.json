              "raw": "{\n  \"From_IATACODE\": \"DEL\",\n  \"To_IATACODE\": \"BOM\",\n  \"departure_date\": \"2026-09-15\",\n  \"return_date\": \"\",\n  \"adults\": \"1\",\n  \"children\": \"0\",\n  \"infants\": \"0\",\n  \"isoneway\": \"Yes\",\n  \"Flights_category\": \"Economy\"\n}"
            },
