                  "console.log('[FareRule] data keys:', Object.keys(j.data || {}).join(', '));",
                  "const d = j.data?.responseData?.Response || j.data || {};",
                  "const rules = d.FareRules || [];",
                  "console.log('📋 Fare rules returned:', rules.length);",
